{
  "name": "@laioutr/app-hygraph",
  "version": "1.7.1",
  "description": "Laioutr Hygraph App",
  "repository": "your-org/@laioutr/app-hygraph",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./codegen": {
      "types": "./dist/codegen/index.d.mts",
      "import": "./dist/codegen/index.mjs"
    },
    "./queries": {
      "types": "./dist/queries/index.d.mts",
      "import": "./dist/queries/index.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "runtime": [
        "./dist/runtime/index.d.ts"
      ],
      "codegen": [
        "./dist/codegen/index.d.mts"
      ],
      "queries": [
        "./dist/queries/index.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "npm run dev:prepare && nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "lint": "eslint .",
    "prepack": "nuxt-module-build build",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish --access public && git push --follow-tags",
    "test": "vitest run",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@nuxt/kit": "3.16.2",
    "zod": "3.25.61"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@laioutr-app/ui": "^1.32.2",
    "@laioutr-core/orchestr-devtools": "^1.7.0-next.0",
    "@laioutr/eslint-config": "^1.8.8",
    "@laioutr/prettier-config": "^1.1.0",
    "@nuxt/devtools": "^2.6.3",
    "@nuxt/devtools-ui-kit": "2.5.0",
    "@nuxt/module-builder": "1.0.1",
    "@nuxt/schema": "3.16.2",
    "@nuxt/test-utils": "3.19.1",
    "@pinia/colada": "0.17.1",
    "@pinia/colada-nuxt": "0.2.1",
    "@types/node": "latest",
    "@vueuse/core": "13.1.0",
    "changelogen": "^0.6.2",
    "eslint": "^9.35.0",
    "graphql": "^16.13.1",
    "nuxt": "3.16.2",
    "pinia": "3.0.2",
    "typescript": "5.9.2",
    "vitest": "3.1.1",
    "vue-tsc": "2.2.10"
  },
  "peerDependencies": {
    "@graphql-codegen/cli": "^6.0.0",
    "@laioutr-core/canonical-types": ">=0.25.0",
    "@laioutr-core/core-types": ">=0.33.1",
    "@laioutr-core/frontend-core": ">=0.33.1",
    "@laioutr-core/kit": ">=0.33.1",
    "graphql": "^16.0.0"
  },
  "peerDependenciesMeta": {
    "@graphql-codegen/cli": {
      "optional": true
    },
    "graphql": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.15.0"
  }
}
